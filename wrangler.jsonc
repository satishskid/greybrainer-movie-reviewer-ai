{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "greybrainer-omnichannel-api",
  "account_id": "9f4998a66a5d7bd7a230d0222544fbe6",
  "main": "worker/src/index.ts",
  "compatibility_date": "2026-03-11",
  "observability": {
    "enabled": true
  },
  "r2_buckets": [
    {
      "binding": "CONTENT_R2",
      "bucket_name": "greybrainer-content"
    },
    {
      "binding": "KNOWLEDGE_R2",
      "bucket_name": "greybrainer-knowledge"
    }
  ],
  "vars": {
    "DAILY_BRIEF_ENABLED": "true",
    "DAILY_BRIEF_TIMEZONE": "Asia/Kolkata",
    "DRAFT_STORAGE_MODE": "r2",
    "GEMINI_MODEL": "gemini-2.0-flash",
    "KNOWLEDGE_STORAGE_MODE": "r2",
    "OMNICHANNEL_API_VERSION": "2026-03-11",
    "WEBSITE_BASE_URL": "https://greybrainer-dev.pages.dev/lens"
  },
  "triggers": {
    "crons": ["30 3 * * *"]
  }
}
