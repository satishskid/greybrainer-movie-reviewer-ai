TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
OMNICHANNEL_API_VERSION=2026-03-11
DAILY_BRIEF_ENABLED=true
DAILY_BRIEF_TIMEZONE=Asia/Kolkata
DRAFT_STORAGE_MODE=r2
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
WEBSITE_BASE_URL=https://greybrainer-dev.pages.dev/lens
MEDIUM_FEED_URL=https://medium.com/feed/@GreyBrainer
KNOWLEDGE_STORAGE_MODE=r2
KNOWLEDGE_SYNC_BATCH_SIZE=4
SOCIAL_TOKEN_ENCRYPTION_KEY=base64-encoded-32-byte-key
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=https://your-worker.example.workers.dev/api/connect/callback/linkedin
LINKEDIN_OAUTH_SCOPES=r_liteprofile w_member_social rw_organization_admin w_organization_social
MEDIUM_CLIENT_ID=your-medium-client-id
MEDIUM_CLIENT_SECRET=your-medium-client-secret
MEDIUM_REDIRECT_URI=https://your-worker.example.workers.dev/api/connect/callback/medium
MEDIUM_OAUTH_SCOPES=basicProfile,publishPost,listPublications
SOCIAL_CONNECT_SUCCESS_URL=https://greybrainer-dev.pages.dev/console/channels
