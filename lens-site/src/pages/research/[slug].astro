---
import EntryArticle from '../../components/EntryArticle.astro';
import { getLensEntries } from '../../data/manifest';

export async function getStaticPaths() {
  const entries = await getLensEntries();
  return entries.filter((entry) => entry.contentType === 'study').map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<EntryArticle entry={entry} />
