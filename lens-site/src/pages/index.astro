---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import EditorialShelf from '../components/EditorialShelf.astro';
import MethodologyPromo from '../components/MethodologyPromo.astro';
import Footer from '../components/Footer.astro';
import { getLensEntries } from '../data/manifest';

const entries = await getLensEntries();
const reviewEntries = entries.filter((entry) => entry.contentType === 'review');
const briefEntries = entries.filter((entry) => entry.contentType === 'brief');
const researchEntries = entries.filter((entry) => entry.contentType === 'study')
  .filter((entry, idx, arr) => arr.findIndex(e => e.slug === entry.slug) === idx);

// Carousel: pick up to 5 recent entries, daily briefs float to top via heroPriority
const heroPool = [...entries]
  .sort((a, b) => (b.heroPriority ?? 0) - (a.heroPriority ?? 0))
  .slice(0, 5);
const latestBriefs = briefEntries.slice(0, 8);
const featuredReviews = reviewEntries.slice(0, 9);
const latestResearch = researchEntries.slice(0, 8);

const indianCinema = entries.filter((entry) => entry.tags.some(tag => tag.toLowerCase().includes('india') || tag.toLowerCase().includes('indian')));

// Deduplicate: collect slugs already shown in the category shelves
const shownSlugs = new Set([
  ...featuredReviews.map(e => e.slug),
  ...latestBriefs.map(e => e.slug),
  ...latestResearch.map(e => e.slug),
  ...heroPool.map(e => e.slug),
]);
const uniqueIndianCinema = indianCinema.filter(e => !shownSlugs.has(e.slug));
---

<BaseLayout
  title="CineCraft — Cinematic Intelligence by GreyBrain"
  description="Structured film criticism, daily OTT intelligence, and cultural research. Where AI analysis meets editorial authority. Reviews, trends, and storytelling decoded."
>
  <SiteHeader />
  {heroPool.length > 0 && <HeroCarousel entries={heroPool} />}

  <MethodologyPromo />

  {featuredReviews.length > 0 && <EditorialShelf items={featuredReviews} title="Reviews" />}
  {latestBriefs.length > 0 && <EditorialShelf items={latestBriefs} title="Daily Briefs" />}
  {latestResearch.length > 0 && <EditorialShelf items={latestResearch} title="Research" />}
  {uniqueIndianCinema.length > 0 && <EditorialShelf items={uniqueIndianCinema.slice(0, 8)} title="Indian Cinema" />}

  <Footer />
</BaseLayout>
