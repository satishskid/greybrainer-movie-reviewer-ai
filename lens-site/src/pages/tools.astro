---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<BaseLayout
  title="Creative Tools | Greybrainer Lens"
  description="AI-powered tools and workshops to inspire your filmmaking and storytelling."
>
  <SiteHeader />
  <section class="shell archive-hero">
    <span class="section-kicker">Inspiration</span>
    <h1>Creative Tools</h1>
    <p>Harness Greybrainer's analysis for your projects. Generate ideas, explore techniques, and learn from cinematic masters.</p>
  </section>
  <section class="shell">
    <p>Creative tools and workshops coming soon. Stay tuned for AI prompts, story workshops, and filmmaking resources.</p>
  </section>
  <Footer />
</BaseLayout>