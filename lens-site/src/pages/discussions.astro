---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<BaseLayout
  title="Discussions | Greybrainer Lens"
  description="Join the conversation on cinematic analysis, trends, and creative storytelling."
>
  <SiteHeader />
  <section class="shell archive-hero">
    <span class="section-kicker">Community</span>
    <h1>Discussions</h1>
    <p>Engage with fellow movie lovers and creators. Share your thoughts on reviews, trends, and storytelling techniques.</p>
  </section>
  <section class="shell">
    <p>Discussions feature coming soon. Check back for community threads on Greybrainer analyses.</p>
  </section>
  <Footer />
</BaseLayout>